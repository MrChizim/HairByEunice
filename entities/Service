{
  "name": "Service",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the service"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the service"
    },
    "price": {
      "type": "number",
      "description": "Price in GBP"
    },
    "duration": {
      "type": "number",
      "description": "Duration in minutes"
    },
    "category": {
      "type": "string",
      "enum": [
        "braids",
        "cornrows",
        "twists",
        "men",
        "kids"
      ],
      "description": "Service category"
    },
    "image_url": {
      "type": "string",
      "description": "Optional image URL for the service"
    }
  },
  "required": [
    "name",
    "price",
    "duration",
    "category"
  ]
}
